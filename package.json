{
  "name": "my-forever-dates",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migrations:up && next dev",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "wait-for-postgres": "node -r dotenv/config --env-file=.env.development -e \"require('./infra/scripts/wait-for-postgres.ts')\"",
    "migrations:up": "node -r dotenv/config --env-file=.env.development -e \"require('./models/migrator.ts').default.runPendingMigrations()\"",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "node --env-file=.env.development ./node_modules/.bin/jest --detectOpenHandles --runInBand --forceExit",
    "test:watch": "node --env-file=.env.development ./node_modules/.bin/jest --watch --runInBand",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-connect": "^1.0.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@faker-js/faker": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
