{
  "name": "my-forever-dates",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migrations:up && next dev",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "wait-for-postgres": "tsx --env-file=.env.development infra/scripts/wait-for-postgres.ts",
    "migrations:up": "tsx --env-file=.env.development infra/scripts/migrations-up.ts",
    "migrations:up:production": "tsx infra/scripts/migrations-up.ts",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "test": "node --env-file=.env.development node_modules/jest/bin/jest.js --detectOpenHandles --runInBand --forceExit",
    "test:watch": "node --env-file=.env.development node_modules/jest/bin/jest.js --watch --runInBand",
    "prepare": "husky"
  },
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.19.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@faker-js/faker": "^10.3.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
