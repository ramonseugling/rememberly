# Environment Variables

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker): postgres://local_user:local_password@localhost:5432/rememberly
# Production (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Optional: custom CA certificate for SSL (only needed if your provider requires it)
# POSTGRES_CA=

# ─── Migrations ───────────────────────────────────────────────────────────────
# Secret token to authorize POST /api/v1/migrations
# Generate with: openssl rand -hex 32
MIGRATIONS_TOKEN=

# ─── Resend (email notifications) ────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
# Sender address (must be from a verified domain in Resend)
EMAIL_FROM=rememberly <noreply@rememberly.com.br>

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret token to authorize the daily notification cron job
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL of the app (used to build links in emails)
APP_URL=

# ─── Axiom (logging) ──────────────────────────────────────────────────────────
# Get dataset and token at axiom.co
AXIOM_DATASET=
AXIOM_TOKEN=
